# Impede listagem de diretórios
Options -Indexes

# URLs limpas: /vcard -> vcard.php, /cartao -> cartao.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^vcard/?$ vcard.php [L]
  RewriteRule ^cartao/?$ cartao.html [L]
  RewriteRule ^autor/([a-z0-9-]+)/?$ autor.php?slug=$1 [L,QSA]
</IfModule>

# Bloqueia acesso direto a qualquer arquivo de banco de dados, caso seja
# colocado aqui por engano (o correto é manter fora de public_html,
# como explicado no LEIA-ME.md)
<FilesMatch "\.(sqlite|sqlite3|db)$">
  Require all denied
</FilesMatch>

# Cabeçalhos básicos de segurança
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
